{
    "manifest_version": 3,
    "name": "OVIForm Autofill Extension",
    "version": "1.1",
    "description": "Fill out IDEXX Neo pet client forms quickly!",
    "permissions": ["activeTab", "scripting"],
    "action": {
        "default_popup": "popup.html",
        "default_icon": {
            "16": "public/OVIForm-16x16.png",
            "32": "public/OVIForm-32x32.png",
            "48": "public/OVIForm-48x48.png",
            "128": "public/OVIForm-192x192.png"
        }
    },
    "icons": {
        "16": "public/OVIForm-16x16.png",
        "32": "public/OVIForm-32x32.png",
        "48": "public/OVIForm-48x48.png",
        "128": "public/OVIForm-192x192.png"
    },
    "host_permissions": ["<all_urls>"]
}
